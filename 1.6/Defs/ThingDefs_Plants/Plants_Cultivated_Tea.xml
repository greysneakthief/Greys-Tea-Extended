<?xml version="1.0" encoding="utf-8" ?>
<Defs>

    <!--
        Camellia sinensis var. sinensis — the Chinese tea plant.
        Cold-hardy bush form. Suited to cooler highlands and temperate biomes.
        minGrowthTemperature -10 reflects real-world cold tolerance of mature plants.
        Perennial: dieIfLeafless=false, harvestAfterGrowth=0.40 means it regrows after each pluck.
    -->
    <ThingDef ParentName="PlantBase">
        <defName>GT_CamelliaSinensis</defName>
        <label>tea bush (sinensis)</label>
        <description>Camellia sinensis var. sinensis — the small-leaf Chinese tea plant. Cold-hardy and forgiving, this is the variety cultivated in cooler highlands from Fujian to Darjeeling to Kenya. The leaves are smaller and the flavors typically more delicate than its tropical cousin assamica. Survives moderate frosts that would kill most tea cultivars.</description>
        <statBases>
            <MaxHitPoints>120</MaxHitPoints>
            <Nutrition>0.25</Nutrition>
            <Beauty>2</Beauty>
        </statBases>
        <graphicData>
            <texPath>Things/Plant/GT_CamelliaSinensis</texPath>
            <graphicClass>Graphic_Single</graphicClass>
        </graphicData>
        <selectable>true</selectable>
        <pathCost>20</pathCost>
        <ingestible />
        <plant>
            <fertilityMin>0.6</fertilityMin>
            <fertilitySensitivity>0.7</fertilitySensitivity>
            <dieIfLeafless>false</dieIfLeafless>
            <harvestTag>Standard</harvestTag>
            <maxMeshCount>1</maxMeshCount>
            <harvestedThingDef>VBE_RawTea</harvestedThingDef>
            <harvestAfterGrowth>0.40</harvestAfterGrowth>
            <harvestYield>15</harvestYield>
            <harvestWork>250</harvestWork>
            <sowMinSkill>5</sowMinSkill>
            <drugForHarvestPurposes>True</drugForHarvestPurposes>
            <sowTags>
                <li>Ground</li>
            </sowTags>
            <topWindExposure>0.10</topWindExposure>
            <minGrowthTemperature>-10</minGrowthTemperature>
            <growMinGlow>0.51</growMinGlow>
            <growDays>17</growDays>
            <lifespanDaysPerGrowDays>30</lifespanDaysPerGrowDays>
            <visualSizeRange>0.4~1.2</visualSizeRange>
            <immatureGraphicPath>Things/Plant/GT_CamelliaSinensis_Immature</immatureGraphicPath>
            <wildOrder>2</wildOrder>
            <purpose>Misc</purpose>
            <humanFoodPlant>false</humanFoodPlant>
        </plant>
    </ThingDef>

    <!--
        Camellia sinensis var. assamica — the Assamese tea plant.
        Tropical tree form. Suited to warm, wet biomes only.
        minGrowthTemperature 0 reflects cold-sensitivity; growth stalls at frost.
        Tree pattern: TreeBase parent, harvestFailable, longer growDays.
    -->
    <ThingDef ParentName="TreeBase">
        <defName>GT_CamelliaAssamica</defName>
        <label>tea tree (assamica)</label>
        <description>Camellia sinensis var. assamica — the large-leaf Assam tea tree. The dominant cultivar across India, Sri Lanka's lowlands, and the warmer plantations of Kenya and Vietnam. Yields the bold, malty leaves that anchor most commercial black teas. Cold-sensitive: a hard frost will damage the foliage and a cold winter will outright kill an unprotected planting.</description>
        <graphicData>
            <texPath>Things/Plant/Tree/GT_CamelliaAssamica/Ripe</texPath>
            <graphicClass>Graphic_Single</graphicClass>
            <shadowData>
                <volume>(0.2, 0.35, 0.2)</volume>
                <offset>(0,0,-0.4)</offset>
            </shadowData>
        </graphicData>
        <selectable>true</selectable>
        <statBases>
            <Beauty>3</Beauty>
            <BeautyOutdoors>4</BeautyOutdoors>
            <Nutrition>1.25</Nutrition>
        </statBases>
        <ingestible />
        <plant>
            <lifespanDaysPerGrowDays>20</lifespanDaysPerGrowDays>
            <fertilitySensitivity>0.8</fertilitySensitivity>
            <dieIfLeafless>false</dieIfLeafless>
            <growDays>40</growDays>
            <visualSizeRange>0.4~2.2</visualSizeRange>
            <sowMinSkill>7</sowMinSkill>
            <sowTags>
                <li>Ground</li>
            </sowTags>
            <fertilityMin>0.7</fertilityMin>
            <topWindExposure>0.15</topWindExposure>
            <minGrowthTemperature>0</minGrowthTemperature>
            <growMinGlow>0.51</growMinGlow>
            <immatureGraphicPath>Things/Plant/Tree/GT_CamelliaAssamica/Immature</immatureGraphicPath>
            <leaflessGraphicPath>Things/Plant/Tree/GT_CamelliaAssamica/Leafless</leaflessGraphicPath>
            <harvestWork>500</harvestWork>
            <harvestTag>Standard</harvestTag>
            <harvestYield>30</harvestYield>
            <harvestedThingDef>VBE_RawTea</harvestedThingDef>
            <harvestFailable>true</harvestFailable>
            <harvestAfterGrowth>0.50</harvestAfterGrowth>
        </plant>
    </ThingDef>

</Defs>
